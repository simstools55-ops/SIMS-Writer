{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/SIMS_FEEDBACK_V2.schema.json",
  "title": "SIMS Feedback V2.1 Canonical",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "contract_version",
    "article_id",
    "url",
    "status",
    "diagnosis",
    "primary_intent",
    "query_coverage",
    "preservation_score",
    "change_budget_percent",
    "rewrite_level",
    "rewrite_scope",
    "risk_level",
    "changes",
    "protected_elements",
    "implementation_status",
    "validation",
    "warnings",
    "information",
    "recommendation_reason"
  ],
  "properties": {
    "format": {
      "const": "SIMS_FEEDBACK_V2"
    },
    "contract_version": {
      "const": "2.1"
    },
    "article_id": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNING",
        "IMPROVEMENT_REQUIRED",
        "NO_CHANGE",
        "FAIL"
      ]
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "confidence",
        "reasons"
      ],
      "properties": {
        "code": {
          "enum": [
            "POSITION_OPPORTUNITY",
            "LOW_SAMPLE",
            "CTR_OPPORTUNITY",
            "CONTENT_GAP",
            "INTENT_MISMATCH",
            "QUERY_MIX",
            "STABLE",
            "UNKNOWN"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "primary_intent": {
      "type": "string",
      "minLength": 1
    },
    "query_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "primary",
        "secondary",
        "adjacent",
        "separate_article"
      ],
      "properties": {
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "primary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "adjacent": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "separate_article": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "preservation_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "change_budget_percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "rewrite_level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "rewrite_scope": {
      "enum": [
        "S0",
        "S1",
        "S2",
        "S3",
        "S4",
        "S5"
      ]
    },
    "risk_level": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "status",
          "before",
          "after",
          "reason"
        ],
        "properties": {
          "target": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "proposed",
              "approved",
              "implemented",
              "not_implemented",
              "not_applicable"
            ]
          },
          "before": {
            "type": [
              "string",
              "null"
            ]
          },
          "after": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "protected_elements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "implementation_status": {
      "enum": [
        "proposed",
        "approved",
        "implemented",
        "not_implemented",
        "not_applicable"
      ]
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "failed_rules",
        "warning_rules",
        "passed_rules"
      ],
      "properties": {
        "result": {
          "enum": [
            "PASS",
            "PASS_WITH_WARNING",
            "FAIL",
            "UNVERIFIABLE"
          ]
        },
        "failed_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "warning_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "passed_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "information": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation_reason": {
      "type": "string",
      "minLength": 1
    },
    "site_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "site_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "site_url": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
