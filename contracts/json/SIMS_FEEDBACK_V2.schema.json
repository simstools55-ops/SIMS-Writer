{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/SIMS_FEEDBACK_V2.schema.json",
  "title": "SIMS Feedback V2.1 Canonical Hotfix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "contract_version",
    "article_id",
    "article_url",
    "diagnosis",
    "query_coverage",
    "changes",
    "implementation_status",
    "validation",
    "warnings",
    "information"
  ],
  "properties": {
    "format": {
      "const": "SIMS_FEEDBACK_V2"
    },
    "contract_version": {
      "const": "2.1"
    },
    "site_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "site_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "site_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "article_id": {
      "type": "string",
      "minLength": 1
    },
    "article_url": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "confidence",
        "reasons"
      ],
      "properties": {
        "code": {
          "enum": [
            "POSITION_OPPORTUNITY",
            "LOW_SAMPLE",
            "CTR_OPPORTUNITY",
            "CONTENT_GAP",
            "INTENT_MISMATCH",
            "QUERY_MIX",
            "STABLE",
            "UNKNOWN"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "main_query": {
          "type": [
            "string",
            "null"
          ]
        },
        "main_query_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "sample_size_flag": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "primary_intent": {
      "type": [
        "string",
        "null"
      ]
    },
    "query_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coverage_confidence",
        "primary",
        "secondary",
        "adjacent",
        "separate_article"
      ],
      "properties": {
        "captured_impressions": {
          "type": [
            "number",
            "null"
          ]
        },
        "total_impressions": {
          "type": [
            "number",
            "null"
          ]
        },
        "coverage_percent": {
          "type": [
            "number",
            "null"
          ]
        },
        "coverage_confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "primary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "adjacent": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "separate_article": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "execution_mode": {
      "type": [
        "string",
        "null"
      ]
    },
    "preservation_score": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "rewrite_level": {
      "type": [
        "string",
        "null"
      ]
    },
    "rewrite_scope": {
      "type": [
        "string",
        "null"
      ]
    },
    "change_budget_percent": {
      "type": [
        "number",
        "null"
      ]
    },
    "estimated_change_percent": {
      "type": [
        "number",
        "null"
      ]
    },
    "risk_level": {
      "type": [
        "string",
        "null"
      ]
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "implementation_status",
          "before",
          "after",
          "reason"
        ],
        "properties": {
          "target": {
            "type": "string",
            "minLength": 1
          },
          "implementation_status": {
            "enum": [
              "proposed",
              "approved",
              "implemented",
              "not_implemented",
              "not_applicable"
            ]
          },
          "before": {
            "type": [
              "string",
              "null"
            ]
          },
          "after": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "new_values": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    },
    "improvement_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        null
      ]
    },
    "expected_effect": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    },
    "next_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "recommended_review_days": {
      "type": [
        "integer",
        "null"
      ]
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "implementation_status": {
      "enum": [
        "proposed",
        "approved",
        "implemented",
        "not_implemented",
        "not_applicable"
      ]
    },
    "protected_elements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "information": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "checks",
        "failed_rules",
        "warning_rules",
        "passed_rules",
        "notes"
      ],
      "properties": {
        "result": {
          "enum": [
            "PASS",
            "PASS_WITH_WARNING",
            "FAIL",
            "UNVERIFIABLE"
          ]
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "failed_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warning_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "passed_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "estimated_minutes": {
      "type": [
        "integer",
        "number",
        "null"
      ]
    },
    "swls": {
      "type": [
        "object",
        "null"
      ]
    },
    "recommendation_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
